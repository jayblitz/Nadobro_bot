modules = ["python-3.11"]
[agent]
expertMode = true

[workflows]

[[ports]]
localPort = 8080
externalPort = 80

[[ports]]
localPort = 8099
externalPort = 8099

[nix]
channel = "stable-25_05"
packages = ["cargo", "libiconv", "libxcrypt", "openssl", "pkg-config", "rustc"]

[userenv]

[userenv.shared]
TELEGRAM_TRANSPORT = "webhook"
TELEGRAM_WEBHOOK_URL = "https://nadobro-bot.fly.dev/telegram/webhook"
TELEGRAM_WEBHOOK_PATH = "/telegram/webhook"
