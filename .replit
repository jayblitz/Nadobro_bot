modules = ["python-3.11"]
[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Nadobro Bot"

[[workflows.workflow]]
name = "Nadobro Bot"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python main.py"
waitForPort = 8099

[workflows.workflow.metadata]
outputType = "console"

[[ports]]
localPort = 8099
externalPort = 8099

