# Nadobro — Telegram bot for Perps on Nado
# Copy to .env and fill in values.

# Required
TELEGRAM_TOKEN=your_bot_token_from_botfather
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_service_role_key

# Wallet encryption (required for key validation at startup)
ENCRYPTION_KEY=your_fernet_key_base64_or_32_char_secret

# Optional: AI support (Ask Nado)
# XAI_API_KEY=
# OPENAI_API_KEY=

# Optional: Admin Telegram user IDs (comma-separated)
# ADMIN_USER_IDS=123456789

# Optional: Auto-restore strategy bots on startup
# NADO_AUTO_RESTORE_STRATEGIES=false

# Optional: Card-based UI
# DUAL_MODE_CARD_FLOW=true
